{
  "name": "poeticsoft/heart",
  "description": "Núcleo del ecosistema Poeticsoft para WordPress",
  "type": "wordpress-plugin",
  "version": "0.0.0",
  "license": "GPL-3.0-or-later",
  "authors": [
    {
      "name": "Poeticsoft",
      "email": "alberto@poeticsoft.com"
    }
  ],
  "require": {
    "php": ">=7.4",
    "yahnis-elsts/plugin-update-checker": "^5.0"
  },
  "autoload": {
    "psr-4": {
      "Poeticsoft\\": "class/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "allow-plugins": {
      "composer/installers": true
    }
  },
  "require-dev": {
    "squizlabs/php_codesniffer": "^4.0",
    "wp-cli/wp-cli-bundle": "^2.12"
  },
  "scripts": {
    "make-pot": "vendor\\bin\\wp.bat i18n make-pot . languages/poeticsoft-heart.pot --exclude=vendor",  
    "format": "phpcbf .",
    "lint": "phpcs .",
    "fix": [
        "@format",
        "@lint"
    ],
    "estructura": "php tools\\estructura.php",
    "plugin": "php tools\\plugin.php",
    "doc": [
        "@estructura",
        "@plugin"
    ],
    "fixdoc": [
        "@fix",
        "@doc"
    ]
  }
}