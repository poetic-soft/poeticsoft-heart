:root {
  /* SIZES */
  --space: 8px;
  --s025: calc(var(--space) * 0.25);
  --s05: calc(var(--space) * 0.5);
  --s075: calc(var(--space) * 0.75);
  --s: var(--space);
  --s15: calc(var(--space) * 1.5);
  --s2: calc(var(--space) * 2);
  --s3: calc(var(--space) * 3);
  --s4: calc(var(--space) * 4);
  --s5: calc(var(--space) * 5);
  --s6: calc(var(--space) * 6);
  --s7: calc(var(--space) * 7);
  --s8: calc(var(--space) * 8);
  --s9: calc(var(--space) * 9);
  --s10: calc(var(--space) * 10);
  --s12: calc(var(--space) * 12);
  --s14: calc(var(--space) * 14);
  --s20: calc(var(--space) * 14);
  --color-grey-a: #ccc;
  --color-grey-b: #888888;
}

.postbox .inside .DashboardWidget .Portal .dashboard-options .option-field {
  display: flex;
  justify-content: space-between;
  gap: var(--s);
}
.postbox .inside .DashboardWidget .Portal .dashboard-options .option-field .field {
  flex: 1;
}
.postbox .inside .DashboardWidget .Portal .dashboard-options .option-field button {
  margin-top: var(--s3);
}
.postbox .inside .DashboardWidget .Portal .dashboard-sections-options .section > .title {
  font-weight: bold;
  padding: 0 0 var(--s025) 0;
  border: solid 1px;
  border-width: 0 0 1px 0;
  color: var(--color-grey-b);
}
.postbox .inside .DashboardWidget .Portal .dashboard-sections-options .section .options .option {
  border: dotted 1px;
  border-width: 0 0 1px 0;
  padding: var(--s05) 0;
  display: flex;
  flex-wrap: wrap;
  gap: var(--s);
}
.postbox .inside .DashboardWidget .Portal .dashboard-sections-options .section .options .option .name {
  font-weight: bold;
}
.postbox .inside .DashboardWidget .Portal .dashboard-sections-options .section + .section {
  margin: var(--s2) 0 0 0;
}

.Metabox.route .Portal .playmotiv-page-route-wrapper .route-display {
  padding: var(--s);
  text-align: center;
  border: solid 1px var(--color-borders);
  cursor: help;
}
.Metabox.route .Portal .playmotiv-page-route-wrapper > .components-button {
  width: 100%;
  box-sizing: border-box;
  justify-content: center;
}
.Metabox.route .Portal .playmotiv-page-route-wrapper .components-notice {
  margin-top: var(--s2);
}